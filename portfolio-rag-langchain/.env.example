# Alin ang gagamitin: "ollama" (local, libre, mabagal) o "groq" (cloud, mabilis, may free tier)
LLM_PROVIDER=ollama

# Kailangan lang kapag LLM_PROVIDER=ollama
# OLLAMA_MODEL=gemma2:2b
OLLAMA_MODEL=qwen2.5:0.5b

# Kailangan lang kapag LLM_PROVIDER=groq
# Kunin dito ang API key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant